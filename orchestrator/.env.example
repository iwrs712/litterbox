# 本地开发环境变量（复制为 .env 后按需修改）
# docker compose 会自动读取同目录下的 .env 文件

# Kubeconfig 路径（默认 ~/.kube/config）
# 如果要连接远程集群，改为对应路径：
# KUBECONFIG=/path/to/k3s.yaml
KUBECONFIG=~/.kube/config

# K8s namespace（sandbox 资源创建在哪个 namespace）
K8S_NAMESPACE=default

# API 监听端口（宿主机端口，容器内固定 8080）
API_PORT=8080

# Sandbox 基础域名（用于生成 ingress host）
BASE_DOMAIN=localhost
